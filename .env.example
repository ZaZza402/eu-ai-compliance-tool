# ==============================================================================
# Regumatrix — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Clerk Authentication
# https://dashboard.clerk.com → Your App → API Keys
# ------------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME

# Clerk redirect URLs (these match the route structure)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ------------------------------------------------------------------------------
# Database (Supabase PostgreSQL)
# https://supabase.com → Your Project → Settings → Database → Connection String
# Use the "Transaction" pool mode URL for serverless (port 6543)
# Use the "Session" mode URL (port 5432) for prisma migrate commands
# ------------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# ------------------------------------------------------------------------------
# Google Gemini AI
# https://aistudio.google.com → Get API key
# ------------------------------------------------------------------------------
GOOGLE_GENERATIVE_AI_API_KEY=REPLACE_ME

# ------------------------------------------------------------------------------
# PayPal
# https://developer.paypal.com → Apps & Credentials
# Use SANDBOX credentials for development, LIVE for production
# ------------------------------------------------------------------------------
PAYPAL_CLIENT_ID=REPLACE_ME
PAYPAL_CLIENT_SECRET=REPLACE_ME
NEXT_PUBLIC_PAYPAL_CLIENT_ID=REPLACE_ME
PAYPAL_WEBHOOK_ID=REPLACE_ME
# Set to "sandbox" for dev, "production" for live
PAYPAL_ENVIRONMENT=sandbox

# ------------------------------------------------------------------------------
# App
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://regumatrix.eu

# ------------------------------------------------------------------------------
# Email / Contact forwarding
# The /api/contact serverless route uses Resend to forward feedback to your inbox.
# https://resend.com → API Keys
# CONTACT_TO_EMAIL = the address that receives feedback (your personal inbox)
# RESEND_FROM_EMAIL = verified sender address in your Resend account
# ------------------------------------------------------------------------------
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_EMAIL=noreply@yourdomain.com
CONTACT_TO_EMAIL=info@alecsdesign.xyz
